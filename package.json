{
  "name": "darkodds",
  "version": "0.0.0",
  "private": true,
  "description": "DarkOdds — confidential prediction market on Arbitrum Sepolia.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "healthcheck": "tsx tools/healthcheck.ts",
    "lint": "pnpm --filter web run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml,css,sol}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml,css,sol}\"",
    "typecheck": "pnpm --filter web run typecheck && tsc --noEmit -p tsconfig.json",
    "test:contracts": "forge test --root contracts",
    "dev:web": "pnpm --filter web run dev",
    "build:web": "pnpm --filter web run build",
    "prepare": "husky"
  },
  "dependencies": {
    "@iexec-nox/handle": "0.1.0-beta.10",
    "viem": "2.48.4"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.3",
    "prettier-plugin-solidity": "2.3.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml,css}": [
      "prettier --write"
    ],
    "*.sol": [
      "prettier --write"
    ],
    "web/**/*.{ts,tsx}": [
      "pnpm --filter web exec eslint --fix --max-warnings=0"
    ]
  },
  "packageManager": "pnpm@10.33.0"
}
