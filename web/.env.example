# DarkOdds web app — Next.js client-side env vars.
#
# NEXT_PUBLIC_* prefix bundles these into the client JS, so DO NOT put secrets
# here. Server-side env vars live in the repo-root .env (sourced by tools/*).
#
# Copy this file to web/.env.local and fill in the values for local dev.

# Privy app ID — created at app.privy.io.
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id-here

# Arbitrum Sepolia RPC. Mirror the one in repo-root .env so wagmi reads the
# same provider as tools/healthcheck.ts.
NEXT_PUBLIC_ARB_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# ChainGPT API key — server-only (no NEXT_PUBLIC_ prefix). Powers /create page
# (market generation) and tools/chaingpt-audit.ts (CI audit). Get from the
# ChainGPT dashboard at https://app.chaingpt.org.
CHAINGPT_API_KEY=your-chaingpt-api-key-here
